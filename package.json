{
  "name": "dofus-tracker",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "sync": "pnpm --filter @dofus-tracker/sync run start",
    "postinstall": "pnpm --filter @dofus-tracker/types build && pnpm --filter @dofus-tracker/db build"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.28",
      "react-native-worklets": "~0.4.0"
    }
  }
}
