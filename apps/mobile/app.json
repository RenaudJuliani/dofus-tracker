{
  "expo": {
    "name": "Dofus Tracker",
    "slug": "dofus-tracker",
    "version": "1.0.0",
    "scheme": "dofustracker",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#080e0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dofustracker.app"
    },
    "android": {
      "package": "com.dofustracker.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#080e0a"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0989a302-3ac2-4964-9249-65d529b0cb1f"
      }
    },
    "owner": "stow"
  }
}
